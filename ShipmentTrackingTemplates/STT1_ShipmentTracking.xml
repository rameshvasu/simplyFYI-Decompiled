<shippingtrackingtemplate>
  <editorplaceholdermarkup>
    <div style="display:table">[%SHIPMENTTRACKINGDETAILS%]</div>
  </editorplaceholdermarkup>
  <editorplaceholdermarkup2column>
    <div style="display:table">[%SHIPMENTTRACKINGDETAILS_2COLUMN%]</div>
  </editorplaceholdermarkup2column>
  <details>
    <![CDATA[
        <div>
          <div style="width:500px; border:solid 1px #dadada; font-family:Arial; font-size:14px; font-weight:normal; padding: 5px 5px 5px 5px;vertical-alignment:top">
            <table style="width:500px;background:#fff;">
              <tr>
                <td colspan=2 style="font-size:16px; font-family:Arial;padding:5px; text-align:center; border-bottom:solid 1px #dadada;" valign="middle">Tracking #: {shipping_tracking_number}</td>
              </tr>
              <tr>
                <td  style="text-align:center; width: 200px; border:none" valign="center">
                  <img style="padding:5px" src="{shipping_carrier_image}"/>
                </td>
                <td style="text-align:center; font-size:12px; font-family:Arial;padding:5px; border:none" valign="center"><a href='{shipping_tracking_link}' target='_blank'>Track package</a></td>
              </tr>
            </table>    
          </div>  
        </div>
        <br/>
    ]]>
  </details>
  <details2column>
    <![CDATA[
        <div>
          <div style="width:400px; border:solid 1px #dadada; font-family:Arial; font-size:14px; font-weight:normal; padding: 5px 5px 5px 5px;vertical-alignment:top">
            <table style="width:400px;background:#fff;">
              <tr>
                <td colspan=2 style="font-size:16px; font-family:Arial;padding:5px; text-align:center; border-bottom:solid 1px #dadada;" valign="middle">Tracking #: {shipping_tracking_number}</td>
              </tr>
              <tr>
                <td  style="text-align:left; width: 200px; border:none" valign="center">
                  <img style="padding:5px" src="{shipping_carrier_image}"/>
                </td>
                <td style="text-align:left; font-size:12px; font-family:Arial;padding:5px; border:none" valign="center"><a href='{shipping_tracking_link}' target='_blank'>Track package</a></td>
              </tr>
            </table>    
          </div>  
        </div>
        <br/>
    ]]>
  </details2column>
</shippingtrackingtemplate>
